#!/bin/bash
# Block commits that contain real credentials in .install or .backup.
set -euo pipefail

CREDENTIAL_PATTERN='^(SERVER_IP|[A-Z0-9_]*_PASS(WORD)?|MOUNT_[0-9]+_USER|MOUNT_[0-9]+_ADDRESS|[A-Z0-9_]*_FQDN)=[[:space:]]*[^#[:space:]]'
SENSITIVE_FILES=(".install" ".backup")

FAILED=0
for file in "${SENSITIVE_FILES[@]}"; do
    git diff --cached --name-only | grep -qF "$file" || continue

    staged=$(git show ":$file" 2>/dev/null) || continue

    hits=$(echo "$staged" | grep -En "$CREDENTIAL_PATTERN" || true)
    if [ -n "$hits" ]; then
        echo "pre-commit: credentials detected in staged $file — commit blocked" >&2
        echo "$hits" | sed 's/^/  /' >&2
        FAILED=1
    fi
done

if [ "$FAILED" -ne 0 ]; then
    echo "" >&2
    echo "Blank out all credential fields before committing." >&2
    exit 1
fi
